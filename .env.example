# The single central settings file. Copy to .env and edit. / 設定を一元管理する中央ファイル。.env にコピーして編集。
# Read by docker compose (env_file + ${VAR} substitution), run_local.sh, and the agent.
# docker compose（env_file と ${VAR} 展開）・run_local.sh・エージェントが参照する。

# ---- What to run / 実行内容 ----
LANG_CODE=en                 # jp | en  (applies to both environments / 両環境に適用)
CONDITION=baseline           # baseline | analysis_only | utterance_fewshot |
                             # utterance_fewshot_analysis | script_fewshot | script_fewshot_analysis

# ---- Werewolf (compose --profile aiwolf) / 人狼 ----
AIWOLF_SERVER_CONFIG=default_5.yml
AIWOLF_PORT=8080
AIWOLF_TEAM=discussion-bench-wolf
AIWOLF_NUM=5

# ---- HiddenBench (compose --profile hiddenbench) ----
HB_PORT=8090
HB_TEAM=discussion-bench-hb
HB_TASK_LIMIT=20             # how many of the 65 tasks to run / 全65タスクのうち何件を回すか
HB_TOTAL_ROUNDS=15
# HiddenBench agent count is fixed at 4. / HiddenBench のエージェント数は4で固定。

# ---- LLM provider API keys / LLMプロバイダのAPIキー ----
# Set the key(s) for whatever providers your components use. / 使うプロバイダのキーを設定。
OPENAI_API_KEY=
GOOGLE_API_KEY=
# Anthropic / Claude is read as ANTHROPIC_API_KEY (agent, generator, judge all use this).
# Anthropic/Claude のキーは ANTHROPIC_API_KEY として読まれる（agent・generator・judge 共通）。
ANTHROPIC_API_KEY=

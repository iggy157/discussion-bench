# INLG — the SINGLE central .env. Copy to .env and edit. / 唯一の中央env。.envにコピーして編集。
# Referenced by docker compose (env_file + ${VAR} substitution) AND run_local.sh AND the
# agent (loads inlg/.env). One file controls the whole system.
# compose・run_local・エージェントの全てがこの1ファイルを参照する。

# ---- What to run / 実行内容 ----
LANG_CODE=en                 # jp | en  (applies to both domains)
CONDITION=baseline           # baseline | analysis_only | utterance_fewshot |
                             # utterance_fewshot_analysis | script_fewshot | script_fewshot_analysis

# ---- Werewolf (compose --profile aiwolf) ----
AIWOLF_SERVER_CONFIG=default_5.yml
AIWOLF_PORT=8080
AIWOLF_TEAM=inlg-wolf
AIWOLF_NUM=5

# ---- HiddenBench (compose --profile hiddenbench) ----
HB_PORT=8090
HB_TEAM=inlg-hb
HB_TASK_LIMIT=20             # how many of the 65 tasks to run (keep disjoint from exemplar tasks)
HB_TOTAL_ROUNDS=15           # faithful T=15
# HiddenBench agent count is fixed at 4 (canonical).

# ---- LLM provider API keys (passed to agents) / LLMプロバイダのAPIキー ----
# Match the provider in the agent's mode config (openai by default).
OPENAI_API_KEY=
GOOGLE_API_KEY=
# Anthropic key is read as CLAUDE_API_KEY (not ANTHROPIC_API_KEY) by the agent.
CLAUDE_API_KEY=

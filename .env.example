# The single central settings file. Copy to .env and edit.
# (Japanese-commented copy: .env.ja.example)
# Read by docker compose (env_file + ${VAR} substitution), run_local.sh, and the agent.

# ---- What to run ----
LANG_CODE=en                 # jp | en  (applies to both environments)
CONDITION=baseline           # baseline | analysis_only | utterance_fewshot |
                             # utterance_fewshot_analysis | script_fewshot | script_fewshot_analysis

# ---- Werewolf (compose --profile aiwolf) ----
AIWOLF_SERVER_CONFIG=default_5.yml
AIWOLF_PORT=8080
AIWOLF_TEAM=discussion-bench-wolf
AIWOLF_NUM=5

# ---- HiddenBench (compose --profile hiddenbench) ----
HB_PORT=8090
HB_TEAM=discussion-bench-hb
HB_TASK_LIMIT=20             # how many of the 65 tasks to run
HB_TOTAL_ROUNDS=15
# HiddenBench agent count is fixed at 4.

# ---- LLM provider API keys (passed to agents) ----
# Match the provider in the agent's config (openai by default).
OPENAI_API_KEY=
GOOGLE_API_KEY=
# Anthropic key is read as CLAUDE_API_KEY (not ANTHROPIC_API_KEY) by the agent.
CLAUDE_API_KEY=

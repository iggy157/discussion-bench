# INLG system configuration — copy to .env and edit / .env にコピーして編集.
# This single file (+ compose profiles) is the knob for "what runs".

# ---- What to run / 実行内容 ----
# Language: jp | en (applies to both domains) / 言語
LANG_CODE=en
# Experiment condition (one of the 3x2 cells; needs exemplars for non-baseline):
#   baseline | analysis_only | utterance_fewshot | utterance_fewshot_analysis |
#   script_fewshot | script_fewshot_analysis
CONDITION=baseline

# ---- Werewolf (profile: aiwolf) ----
AIWOLF_SERVER_CONFIG=default_5.yml
AIWOLF_PORT=8080
AIWOLF_TEAM=inlg-wolf
AIWOLF_NUM=5

# ---- HiddenBench (profile: hiddenbench) ----
HB_PORT=8090
HB_TEAM=inlg-hb
# HiddenBench agent count is fixed at 4 (canonical) and not overridable here.

# ---- LLM provider API keys (passed to agents) / LLMプロバイダのAPIキー ----
# Match the provider set in the agent's mode config (openai by default).
OPENAI_API_KEY=
GOOGLE_API_KEY=
# Anthropic key is read as CLAUDE_API_KEY (not ANTHROPIC_API_KEY) by the agent.
CLAUDE_API_KEY=

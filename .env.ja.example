# 設定を一元管理する中央ファイル。.env にコピーして編集する。
# （英語コメント版: .env.example）
# docker compose（env_file と ${VAR} 展開）・run_local.sh・エージェントが参照する。

# ---- 実行内容 ----
LANG_CODE=en                 # jp | en （両環境に適用）
CONDITION=baseline           # baseline | analysis_only | utterance_fewshot |
                             # utterance_fewshot_analysis | script_fewshot | script_fewshot_analysis

# ---- 人狼（compose --profile aiwolf）----
AIWOLF_SERVER_CONFIG=default_5.yml
AIWOLF_PORT=8080
AIWOLF_TEAM=discussion-bench-wolf
AIWOLF_NUM=5

# ---- HiddenBench（compose --profile hiddenbench）----
HB_PORT=8090
HB_TEAM=discussion-bench-hb
HB_TASK_LIMIT=20             # 全65タスクのうち何件を回すか
HB_TOTAL_ROUNDS=15
# HiddenBench のエージェント数は4で固定。

# ---- LLMプロバイダのAPIキー（エージェントに渡す）----
# エージェント設定で使うプロバイダに合わせる（既定は openai）。
OPENAI_API_KEY=
GOOGLE_API_KEY=
# Anthropic のキーは ANTHROPIC_API_KEY ではなく CLAUDE_API_KEY として読まれる。
CLAUDE_API_KEY=

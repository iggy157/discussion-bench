# aiwolf-nlp-demo: 会場配信用 Caddy 設定
#  - 静的ビューア（/demo 含む）をルート配信
#  - /ws        -> game-server（WebSocket。wss はここで TLS 終端）
#  - /api/*      -> lobby（採番・キュー・AI spawn）
#
# サイトアドレスは環境変数で切替:
#   ローカル: DEMO_SITE_ADDRESS=:80        -> http://localhost で検証（ws://localhost/ws）
#   本番   : DEMO_SITE_ADDRESS=demo.example.com -> Caddy が自動で Let's Encrypt TLS（wss://）
{$DEMO_SITE_ADDRESS::80} {
	encode gzip

	# 採番・キュー・AI spawn API
	handle /api/* {
		reverse_proxy lobby:8002
	}

	# 9人村サーバへの WebSocket（/ws9 を内部 /ws に書き換えて転送）
	handle /ws9 {
		rewrite * /ws
		reverse_proxy game-server-9:8080
	}

	# 5人村サーバへの WebSocket（Caddy が Upgrade を透過、TLS 終端で wss 化）
	handle /ws {
		reverse_proxy game-server:8080
	}

	# HiddenBench サーバへの WebSocket（/hb-ws を内部 /ws に書き換えて転送）
	handle /hb-ws {
		rewrite * /ws
		reverse_proxy hidden-bench-server:8090
	}

	# 言語別サーバへの WebSocket ルート（/ws-<lang>, /ws9-<lang>）。
	# scripts/gen_i18n.py が caddy/langs.caddy を生成し、caddy イメージへ COPY される。
	import /etc/caddy/langs.caddy

	# 静的ビューア（SvelteKit adapter-static の出力。/demo -> demo.html）
	handle {
		root * /srv
		try_files {path} {path}.html {path}/index.html /index.html
		file_server
	}
}

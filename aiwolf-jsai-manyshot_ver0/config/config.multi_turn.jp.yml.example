# Multi-turn モード用の子設定ファイル.
# LLMプロバイダ・モデル・プロンプト定義を含む.
# メインconfigの mode が multi_turn のときに読み込まれる.

# お手本台本 (サンプル対局) の読み込み設定. multi-turn 専用.
# 有効にすると, Agent.initialize() の最初で data/sample_games_md/ 以下の
# Markdown 台本を読み込み, LLM の "事前学習" として llm_message_history に
# (HumanMessage 台本, AIMessage 要約) のペアで積む. 以降の全リクエストで
# コンテキストとして保持される.
#
# ack_mode:
#   llm_summary (既定, 推奨)
#     「議論展開・発話テンポ・話題転換・キャラクター口調の一貫性」「履歴→アクション判断の
#     紐付け」を 300〜500字で要約した AIMessage を llm_message_history に積む.
#     要約は *事前に* prewarm_scenario.py で生成してキャッシュしておき, ゲーム起動時は
#     キャッシュを読むだけ (LLM 呼び出しゼロ). これによりサーバの INITIALIZE タイムアウト
#     (60秒前後) を超えるリスクが無い.
#   static
#     固定の承諾文 (ack_static_text) を AIMessage として積む. API 呼び出しなし.
#     もっともシンプル. 学習効果は llm_summary より弱い可能性あり.
#
# separate_langchain: true のときは talk / action 両系統の履歴に積み,
# target_role ごとに別々の観察観点 (talk=議論運び, action=投票/占い/護衛/襲撃の判断紐付け)
# で要約させる. キャッシュもロール別に保存される.
#
# プロンプトキャッシュ: 台本が大きいため, Anthropic / Gemini の prompt cache
# (長文キャッシュ) が効く構成を推奨.
scenario:
  enabled: true
  # delivery: 'full' (既定, 後方互換) | 'by_day'
  #   full   = 全 manyshot を全 day まとめて INITIALIZE で 1 回だけ feed (旧挙動).
  #   by_day = INITIALIZE で各 manyshot の Day 0 部分 (役職配置 + 0日目章節) のみ feed,
  #            以降は daily_initialize で当該日章節を継ぎ足す. 各日の覚書を Day 別キャッシュ
  #            として持つ (キャッシュキーに day を含めて区別). prewarm_scenario.py は
  #            by_day モードのとき全 day 分を自動で prewarm する.
  delivery: full
  sample_dir: ./data/sample_games_md
  # glob: 単一パターン (文字列) またはパターンのリスト. リストの場合はマッチ結果をマージし
  # 重複パスを除外する. 読み込む台本を一部に絞りたいときはリストで範囲指定する.
  # 例: 006〜015 に絞る場合 ->
  #   glob:
  #     - sample_9_00[6-9].md
  #     - sample_9_01[0-5].md
  glob: sample_9_*.md
  ack_mode: llm_summary
  ack_static_text: "承知しました。台本を参考に、議論展開・発話のテンポ・キャラクターの口調を踏まえて演じます。"
  # --- 要約キャッシュ設定 (ack_mode=llm_summary のとき有効) ---
  # use_cache: true のとき, ゲーム起動時に data/scenario_cache/ を参照し,
  #   (provider, model, lang, target_role, プロンプト本文ハッシュ) でキャッシュを検索.
  #   ヒット → キャッシュの応答をそのまま AIMessage として積む (LLM 呼び出しゼロ).
  #   ミス   → on_cache_miss の設定に従う.
  # キャッシュの事前生成は `uv run scripts/prewarm_scenario.py` で行う.
  use_cache: true
  cache_dir: ./data/scenario_cache
  # on_cache_miss:
  #   static (既定, 推奨): キャッシュ無ければ static_ack にフォールバックしタイムアウトを避ける.
  #     ゲーム起動前に prewarm_scenario.py の実行を推奨.
  #   live: 実行時に LLM を呼び, 得られた応答を今回分としてキャッシュにも保存する.
  #     prewarm を忘れてもその場で生成されるが, INITIALIZE タイムアウトを超えるリスクあり.
  #   error: キャッシュミスを致命エラー扱いして INITIALIZE を失敗させる.
  on_cache_miss: static

llm:
  type: google
  # llm 直下でも model / temperature / pricing_mode / base_url を書けば
  # 下のプロバイダセクション (openai:, google: 等) の値を上書きする (任意).
  # 例: separate_langchain=false のまま google の別モデルを使いたい場合
  # model: gemini-2.5-pro
  sleep_time: 3
  # trueにするとリクエスト種別ごとにLangChainとllm_message_historyを分離する.
  # 共通系 (initialize, daily_initialize, daily_finish) は両方に送信する.
  # 発話系 (talk, whisper) は llm.talk のモデルに送信する.
  # アクション系 (vote, divine, guard, attack) は llm.action のモデルに送信する.
  # falseにするとllm.typeの単一モデル/履歴で従来通り動作する.
  separate_langchain: true
  # talk / action には type の他に model / temperature / pricing_mode / base_url を直接書ける.
  # 指定した項目は下の <provider>: セクションより優先される. 省略した項目は <provider>: から継承.
  # 同じ会社の異なるモデルを talk と action で使い分けたい場合はここに model を書く.
  # type を省略した場合は llm.type をデフォルトとして使う.
  talk:
    type: openai
    model: gpt-4o              # openai + gpt-4o (talk は少し強めのモデル)
  action:
    type: openai
    model: gpt-4o-mini         # openai + gpt-4o-mini (action は軽量モデル)

openai:
  model: gpt-4o-mini
  temperature: 0.7

google:
  model: gemini-2.0-flash-lite
  temperature: 0.7

vertexai:
  model: gemini-2.0-flash-lite
  temperature: 0.7

ollama:
  model: llama3.1
  temperature: 0.7
  base_url: http://localhost:11434

anthropic:
  model: claude-opus-4-5-20251101
  temperature: 1.0
  # Anthropic prompt cache の自動注入. true (default) のとき, 毎コール直前に末尾 HumanMessage
  # 直前の最後の AIMessage に cache_control を自動付与し, scenario + 過去ターンを Anthropic の
  # prompt cache に乗せる. OpenAI の自動キャッシュと同等の効果. false にすると素の挙動 (全額課金).
  cache: true
  # cache TTL: "5m" (default, 1.25× write cost) または "1h" (2× write cost).
  # 1局が 5 分以内に終わるなら 5m で十分. 長引くゲームは 1h を検討.
  cache_ttl: "5m"

# multi-turn モードでは LLM の会話履歴 (llm_message_history) が LangChain 側で保持されるため,
# 各リクエストのプロンプトは最低限のワンラインで足りる.
# ただし llm.separate_langchain=true の場合は talk系 / action系 LangChain が分離され履歴が共有されないため,
# 共通リクエスト (initialize / daily_initialize / daily_finish) のプロンプトで identity / event ブロックを
# include し, 両系統に最低限の情報共有を行う.
prompt:
  # narration_split:
  #   false (default) → 旧来動作. 発話本文だけを LLM に出力させ, ト書き・地の文は禁止.
  #   true → LLM に発話を ``「...」`` で囲ませ, ``「」`` の外側にト書き・地の文を許可する.
  #          サーバには ``「」`` 内側だけが連結されて送信される (extract_dialogue_quotes).
  #          文字数制限は ``「」`` 内側の合計のみに適用される.
  #   注意: true にすると scenario_system / constraints のプロンプト本文が変わるため,
  #         scenario_cache のキーが別キーになる (= 既存キャッシュは使えないので
  #         prewarm を再実行する必要あり, または on_cache_miss=static で fallback 動作).
  narration_split: false

  # 共通リクエスト (initialize / daily_initialize / daily_finish) はゲーム状態のコンテキストを
  # LLM に積むためのもので, 役のセリフを生成させてはいけない. in-character の発話を生成すると
  # llm_message_history に AIMessage として残り, 後続の talk_phase で LLM が「自分が前のターンで
  # 言ったこと」として参照してしまう.
  initialize: |-
    {{ block('identity') }}
    {{ block('instruction') }}
    以降のリクエストには日本語で応答してください。レスポンスはそのままゲームに送信されるため, 不要な情報を含めないでください。

    これはセットアップメッセージです。**役のセリフを生成せず**, 「了解しました」とだけ返してください。実際の発話は後続の talk / whisper リクエストで行います。
  daily_initialize: |-
    {{ block('instruction') }}
    {{ block('event') }}

    これは日付開始の通知です。**役のセリフを生成せず**, 「了解しました」とだけ返してください。実際の発話は後続の talk / whisper リクエストで行います。
  daily_finish: |-
    {{ block('instruction') }}
    {{ block('event') }}
    {% set history_source = talk_history -%}
    {% set history_start = sent_talk_count -%}
    {{ block('history') }}

    これは日付終了の通知です。**役のセリフ・感想・反省を生成せず**, 「了解しました」とだけ返してください。実際の発話は次の日の talk / whisper リクエストで行います。
  talk: |-
    {% set history_source = talk_history -%}
    {% set history_start = sent_talk_count -%}
    {{ block('history') }}
    {{ block('instruction') }}
    {{ block('constraints') }}
  whisper: |-
    {% set history_source = whisper_history -%}
    {% set history_start = sent_whisper_count -%}
    {{ block('history') }}
    {{ block('instruction') }}
    {{ block('constraints') }}
  # アクション系 (vote / divine / guard / attack) では当日の talk_history (attack は whisper_history)
  # を必ずフル展開して再提示する. multi-turn でも separate_langchain=true のときは
  # action LLM の履歴に当日の TALK が積まれない (TALK は talk 系列のみ) ため,
  # ここで明示的に history block を渡さないと LLM は当日の議論を踏まえずに投票してしまう.
  # history_start=0 でフル, history_source は talk_history / whisper_history を切替.
  divine: |-
    {% set history_source = talk_history -%}
    {% set history_start = 0 -%}
    {{ block('history') }}
    {{ block('instruction') }}
    対象:
    {% for k, v in info.status_map.items() -%}
    {%- if v == 'ALIVE' %}{{ k }}
    {% endif -%}
    {%- endfor %}
    {{ block('constraints') }}
  guard: |-
    {% set history_source = talk_history -%}
    {% set history_start = 0 -%}
    {{ block('history') }}
    {{ block('instruction') }}
    対象:
    {% for k, v in info.status_map.items() -%}
    {%- if v == 'ALIVE' %}{{ k }}
    {% endif -%}
    {%- endfor %}
    {{ block('constraints') }}
  vote: |-
    {% set history_source = talk_history -%}
    {% set history_start = 0 -%}
    {{ block('history') }}
    {{ block('instruction') }}
    対象:
    {% for k, v in info.status_map.items() -%}
    {%- if v == 'ALIVE' %}{{ k }}
    {% endif -%}
    {%- endfor %}
    {{ block('constraints') }}
  attack: |-
    {% set history_source = whisper_history -%}
    {% set history_start = 0 -%}
    {{ block('history') }}
    {{ block('instruction') }}
    対象:
    {% for k, v in info.status_map.items() -%}
    {%- if v == 'ALIVE' %}{{ k }}
    {% endif -%}
    {%- endfor %}
    {{ block('constraints') }}

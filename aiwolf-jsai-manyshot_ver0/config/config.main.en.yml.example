# Main configuration file.
# Defines the mode (multi_turn / single_turn) and shared settings (web_socket / agent / log).
# Mode-specific settings (llm / prompt) are loaded from the child config file
# specified in `configs` and merged with this file. On key conflict, the child config wins.

mode: multi_turn
# Language for prompt blocks under prompts/<lang>/. jp / en.
lang: en

# Prompt block heading settings.
# Set enabled: true to prepend a heading to each block's rendered body.
# style: one of markdown | xml.
#   markdown → "### history"
#   xml      → "<history>" ... "</history>" (auto-appends a closing tag)
# Heading text comes from prompts/<lang>/_labels.yml (falls back to the jinja
# filename stem if undefined). For lang=en there is no _labels.yml, so the
# stem (e.g. "history") is used verbatim.
headings:
  enabled: false
  style: markdown

# Profile source.
#   server: use the info.profile string from the server packet as-is (default)
#   local : look up data/prompts/profiles.<lang>.yml by character name (info.agent)
#           and render the rich profile (personality / speech / utterance examples)
#           into identity. The names in profiles.<lang>.yml match the sample scripts
#           under data/sample_games_md, so when the server's custom_profile hands out
#           the same names, each agent is bound to a consistent character.
# If a name does not match locally, the code falls back to info.profile automatically.
profile:
  source: local

configs:
  multi_turn: ./config.multi_turn.en.yml
  single_turn: ./config.single_turn.en.yml

web_socket:
  url: ws://127.0.0.1:8080/ws
  token:
  auto_reconnect: false

agent:
  num: 5
  team: kanolab
  kill_on_timeout: true
  # Whether to enable behavior tuned for the freeform (group-chat) server protocol
  # where the server sends TALK_PHASE_START / TALK_PHASE_END packets.
  #   true: scenario cache is loaded from ``sample_games_<num>_freeform/``. The analysis prompt
  #         includes "next-speaker selection" and "talk-budget-aware behavior" observations.
  #         The constraints prompt shows a ``[PASS]`` control token instruction and the
  #         per-agent remain_talk_map. handle_talk_phase / handle_whisper_phase add a 0–3s
  #         initial stagger and detect ``[PASS]`` to skip the send.
  #   false (default): legacy behavior (always talk on each tick; cache from ``sample_games_<num>/``).
  #         Use this when the server is request/response, or as a safe fallback when accidentally
  #         connecting to a freeform server.
  freeform: false

log:
  console_output: true
  file_output: true
  output_dir: ./log
  level: debug

  request:
    name: false
    initialize: false
    daily_initialize: false
    whisper: true
    talk: true
    daily_finish: false
    divine: true
    guard: true
    vote: true
    attack: true
    finish: false

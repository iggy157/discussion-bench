# メイン設定ファイル.
# モード (multi_turn / single_turn) と共通設定 (web_socket / agent / log) を定義する.
# モード固有の設定 (llm / prompt) は configs で指定された子configファイルから読み込まれ,
# このファイルとマージされる. キー衝突時は子configの値が優先される.

mode: multi_turn
# プロンプトブロック (prompts/<lang>/) の言語. jp / en.
lang: jp

# プロンプトブロックの見出し設定.
# enabled: true にすると各ブロック冒頭に見出しが付与される.
# style: markdown | xml の2種から選択.
#   markdown → "### 履歴"
#   xml      → "<履歴>" ... "</履歴>" (閉じタグも自動付与)
# 見出し文字列は prompts/<lang>/_labels.yml で定義 (未定義ならファイル名をそのまま使用).
headings:
  enabled: false
  style: markdown

# プロフィール情報のソース.
#   server: サーバから送られてくる info.profile 文字列をそのまま使う (既定)
#   local : data/prompts/profiles.<lang>.yml からキャラクター名 (info.agent) をキーに
#           詳細プロフィール (性格・話し方・発話例等) を引いてきて identity に展開する.
#           台本 (data/sample_games_md) のキャラクターと同名で登録されているため,
#           サーバ側が custom_profile で台本と同じ名前を配布していれば自動でマッチする.
# ローカル名に一致しない場合は自動で info.profile へフォールバックするので安全.
profile:
  source: local

configs:
  multi_turn: ./config.multi_turn.jp.yml
  single_turn: ./config.single_turn.jp.yml

web_socket:
  url: ws://127.0.0.1:8080/ws
  token:
  auto_reconnect: false

agent:
  num: 5
  team: kanolab
  kill_on_timeout: true
  # freeform 仕様 (グループチャット方式; サーバが TALK_PHASE_START/END を送る) に最適化した
  # 挙動を有効にするか.
  #   true: scenario cache が ``sample_games_<num>_freeform/`` 配下を参照. 分析プロンプトに
  #         「次発話者の選ばれ方」「残り発話回数を踏まえた振る舞い」観点が追加される. constraints
  #         プロンプトに ``[PASS]`` 制御トークン + 残り発話回数マップが表示される.
  #         handle_talk_phase / handle_whisper_phase が初回 stagger (0〜3秒) と ``[PASS]`` 検出を行う.
  #   false (default): 旧来挙動 (毎ターン必ず talk; cache は ``sample_games_<num>/``).
  #         サーバが request/response 仕様, または freeform サーバへ繋いでもフォールバックで動かしたい時.
  freeform: false

log:
  console_output: true
  file_output: true
  output_dir: ./log
  level: debug

  request:
    name: false
    initialize: false
    daily_initialize: false
    whisper: true
    talk: true
    daily_finish: false
    divine: true
    guard: true
    vote: true
    attack: true
    finish: false
